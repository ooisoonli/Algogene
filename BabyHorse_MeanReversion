from AlgoAPI import AlgoAPIUtil, AlgoAPI_Backtest
from datetime import datetime, timedelta
import numpy as np
import talib

class AlgoEvent:
    def __init__(self):
        self.lasttradetime = datetime(2000, 1, 1)
        self.length = 20
        self.mult = 2.0
        self.hi = 100
        self.lo = 0

        # === Tuned for Gold (XAU/USD) ===
        self.fixedSL               = 0.004   # 0.40%
        self.trailingActivationPct = 0.003   # 0.30% activation
        self.trailingStopPct       = 0.002   # 0.20% trailing distance

        self.myinstrument   = None
        self.open_positions = {}

    def start(self, mEvt):
        self.myinstrument = mEvt['subscribeList'][0]
        self.evt = AlgoAPI_Backtest.AlgoEvtHandler(self, mEvt)
        self.evt.start()

    def on_bulkdatafeed(self, isSync, bd, ab):
        try:
            now = bd[self.myinstrument]['timestamp']

            # ✅ Throttle: once per hour
            if now < self.lasttradetime + timedelta(hours=1):
                return
            self.lasttradetime = now

            lastprice = bd[self.myinstrument]['lastPrice']

            # ✅ Guard: skip if price is invalid
            if not lastprice or lastprice <= 0:
                return

            bars = self.evt.getHistoricalBar(
                {"instrument": self.myinstrument}, self.length + 5, 'H'
            )

            # ✅ Stricter bar check
            if not bars or len(bars) < self.length + 2:
                return

            sorted_keys = sorted(bars)
            closes = np.array([bars[t]['c'] for t in sorted_keys], dtype=float)

            # ✅ Guard: skip if any close is zero or NaN
            if np.any(np.isnan(closes)) or np.any(closes <= 0):
                return

            # === Bollinger Band %B ===
            basis = talib.EMA(closes, timeperiod=self.length)
            dev   = self.mult * talib.STDDEV(closes, timeperiod=self.length, nbdev=1)
            upper = basis + dev
            lower = basis - dev

            # ✅ Guard: avoid division by zero when bands collapse
            band_width = upper[-1] - lower[-1]
            if band_width <= 0:
                return

            bbpct = (closes - lower) / (upper - lower) * 100

            # ✅ Check both last two bars are valid
            if np.isnan(bbpct[-1]) or np.isnan(bbpct[-2]):
                return

            # === Entry Signals ===
            reboundLong  = bbpct[-2] < self.lo and bbpct[-1] > self.lo
            reboundShort = bbpct[-2] > self.hi and bbpct[-1] < self.hi

            # ✅ Reduce console log frequency — only log on signals to avoid crash
            if reboundLong or reboundShort:
                self.evt.consoleLog(
                    f"[{now.strftime('%Y-%m-%d %H:%M')}] "
                    f"BB%={bbpct[-1]:.1f} | Price={lastprice:.2f} | "
                    f"Signal={'LONG' if reboundLong else 'SHORT'}"
                )

            if len(self.open_positions) > 0:
                return

            if reboundLong:
                self.sendOrder(lastprice, 1, 'open')
            elif reboundShort:
                self.sendOrder(lastprice, -1, 'open')

        except Exception as e:
            self.evt.consoleLog(f"⚠️ on_bulkdatafeed error: {str(e)}")

    def sendOrder(self, price, buysell, openclose):
        try:
            order = AlgoAPIUtil.OrderObject()
            order.instrument = self.myinstrument
            order.orderRef   = 1
            order.volume     = 0.2
            order.openclose  = openclose
            order.buysell    = buysell
            order.ordertype  = 0  # Market order

            if buysell == 1:
                order.stopLossLevel      = price * (1 - self.fixedSL)
                order.trailingActivation = price * (1 + self.trailingActivationPct)
            else:
                order.stopLossLevel      = price * (1 + self.fixedSL)
                order.trailingActivation = price * (1 - self.trailingActivationPct)

            order.trailingStop = price * self.trailingStopPct

            self.evt.consoleLog(
                f"📤 {'BUY' if buysell == 1 else 'SELL'} @ {price:.2f} "
                f"| SL={order.stopLossLevel:.2f} "
                f"| Trail activates @ {order.trailingActivation:.2f}"
            )
            self.evt.sendOrder(order)

        except Exception as e:
            self.evt.consoleLog(f"⚠️ sendOrder error: {str(e)}")

    def on_openPositionfeed(self, op, oo, uo):
        try:
            self.open_positions = oo
        except Exception as e:
            self.evt.consoleLog(f"⚠️ on_openPositionfeed error: {str(e)}")

    # Required stubs
    def on_marketdatafeed(self, md, ab):
        pass
    def on_newsdatafeed(self, nd):
        pass
    def on_weatherdatafeed(self, wd):
        pass
    def on_econsdatafeed(self, ed):
        pass
    def on_corpAnnouncement(self, ca):
        pass
    def on_orderfeed(self, of):
        pass
    def on_dailyPLfeed(self, pl):
        pass
